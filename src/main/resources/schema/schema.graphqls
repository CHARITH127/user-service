type Query{
    userById(id:ID) : User
    userByUsername(username: String!): User

}


type Mutation {
    registerUser(input: RegisterInput!): User
    login(username: String!, password: String!): AuthResponse!
}

type AuthResponse {
    token: String!
    user: User!
}

input RegisterInput {
    userName: String!
    password: String!
    role: Role
}

type User{
    id: ID!
    username: String!
    role: Role
}

enum Role {
    USER
    ADMIN
    MANAGER
}